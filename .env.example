# ── Main LLM (worker / reasoning model) ─────────────────────────────────────
# Provider: azure | openai | vllm
PROVIDER=azure
MODEL=gpt-5-mini

# Azure OpenAI credentials (required when PROVIDER=azure)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
OPENAI_API_VERSION=2025-01-01-preview

# OpenAI credentials (required when PROVIDER=openai)
# OPENAI_API_KEY=

# ── Grounding model (required) ────────────────────────────────────────────────
# Self-hosted vLLM endpoint for the coordinate-prediction model
GROUND_PROVIDER=vllm
GROUND_MODEL=meituan/EvoCUA-8B-20260105
GROUND_URL=
GROUND_API_KEY=any-value
GROUNDING_WIDTH=1920
GROUNDING_HEIGHT=1080

# ── Langfuse observability (optional) ────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
