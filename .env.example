# CORTEX Environment Variables

# ── Azure OpenAI (Main Brain) ────────────────────────────────────────────────
AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here
AZURE_OPENAI_ENDPOINT=your_azure_openai_endpoint_here
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-5-mini
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# ── Grounding Model (EvoCUA) ────────────────────────────────────────────────
# Model used for screen grounding and visual tasks
GROUND_MODEL=meituan/EvoCUA-8B-20260105
GROUND_MODEL_URL=your_evocua_endpoint_url_here
GROUND_MODEL_API_KEY=your_evocua_api_key_here

# ── Azure TTS (Optional) ─────────────────────────────────────────────────────
# These will be populated once the user provides the specific code/key
AZURE_OPENAI_AUDIO_ENDPOINT=your_azure_audio_endpoint_here
AZURE_TTS_KEY=your_azure_tts_key_here
AZURE_TTS_REGION=your_azure_tts_region_here

# ── Langfuse (Tracing & Observability) ───────────────────────────────────────
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key_here
LANGFUSE_SECRET_KEY=your_langfuse_secret_key_here
LANGFUSE_HOST=https://cloud.langfuse.com

# ── Slack (Optional MCP Tool) ───────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-...
SLACK_TEAM_ID=T...

# ── Notion (Optional MCP Tool) ──────────────────────────────────────────────
NOTION_API_KEY=secret_...
