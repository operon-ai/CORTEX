{
  "name": "cortex-gui",
  "version": "0.1.0",
  "description": "CORTEX floating control panel",
  "main": "main.js",
  "scripts": {
    "build": "esbuild renderer/app.ts --outfile=renderer/app.js --bundle --platform=browser --target=chrome120",
    "start": "npm run build && electron .",
    "watch": "esbuild renderer/app.ts --outfile=renderer/app.js --bundle --platform=browser --target=chrome120 --watch"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.6.0"
  }
}
