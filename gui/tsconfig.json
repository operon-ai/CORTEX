{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": "renderer",
    "lib": ["ES2022", "DOM", "DOM.Iterable"]
  },
  "include": ["renderer/**/*.ts"]
}
